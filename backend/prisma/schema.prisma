generator client {
    provider = "prisma-client"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model Order {
    id          String       @id @default(cuid())
    customerId  String
    status      OrderStatus  @default(CREATED)
    items       OrderItem[]
    retryCount  Int          @default(0)
    createdAt   DateTime     @default(now())
    updatedAt   DateTime     @updatedAt
    orderEvents OrderEvent[]
}

model OrderItem {
    id        String   @id @default(cuid())
    orderId   String
    order     Order    @relation(fields: [orderId], references: [id])
    sku       String
    quantity  Int
    createdAt DateTime @default(now())
}

model OrderEvent {
    id        String         @id @default(cuid())
    orderId   String
    order     Order          @relation(fields: [orderId], references: [id])
    type      OrderEventType
    message   String
    createdAt DateTime       @default(now())
}

enum OrderEventType {
    ORDER_CREATED
    PROCESSING_STARTED
    PROCESSING_FAILED
    RETRY_REQUESTED
    ORDER_COMPLETED
    RETRY_LIMIT_EXCEEDED
}

enum OrderStatus {
    CREATED
    PROCESSING
    COMPLETED
    FAILED
}
